# ============================================================
#  Invoice.Audit — Environment Variables (example)
#  Copy this file to .env and fill in real values.
#  NEVER commit your actual .env file.
# ============================================================

# --- Database (any PostgreSQL instance — built against Supabase) ---
DATABASE_URL="postgresql://user:password@host:5432/postgres"

# --- Supabase Storage (file uploads, evidence attachments) ---
# Supabase Dashboard → Settings → API
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"
SUPABASE_ANON_KEY="<anon-key>"

# --- Email (Resend) ---
# resend.com → API Keys. EMAIL_FROM must be a Resend-verified sender
# (use the default onboarding@resend.dev sender if you have no custom domain).
RESEND_API_KEY="<resend-api-key>"
EMAIL_FROM="Invoice.Audit <onboarding@resend.dev>"

# --- AI (OpenAI) — required only for real OCR / GST extraction ---
# Demo workspace and the sample-data seeder never call this.
# platform.openai.com → API Keys (needs GPT-4o Vision access)
OPENAI_API_KEY="<openai-api-key>"

# --- Session & audit signing ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="<random-hex-string>"
AUDIT_SIGNING_KEY="<random-hex-string>"

# --- AES-256-GCM key for encrypted ERP credentials ---
# Must be exactly 32 characters.
ENCRYPTION_KEY="<32-character-string>"

# --- Internal cron protection ---
# Generate with the same command as above.
INTERNAL_CRON_KEY="<random-hex-string>"

# --- App ---
PORT=8787
APP_URL="http://localhost:5173"
NODE_ENV="development"

# --- Optional: Google OAuth (SSO login) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Optional: Stripe billing ---
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_FREE=""
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_ANNUAL=""
STRIPE_PRICE_ENTERPRISE=""
VITE_STRIPE_PRICE_FREE=""
VITE_STRIPE_PRICE_PRO_MONTHLY=""
VITE_STRIPE_PRICE_PRO_ANNUAL=""

# --- Optional: error monitoring ---
SENTRY_DSN=""

# --- Feature flags ---
DEMO_SEED_ENABLED="true"
