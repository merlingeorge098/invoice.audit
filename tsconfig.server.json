{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": ".",
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": ["server/**/*", "prisma/seed.ts"],
  "exclude": ["node_modules", "dist", "src"]
}
